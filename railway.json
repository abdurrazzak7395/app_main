{
  "project": "app_main",
  "services": {
    "backend": {
      "path": "backend",
      "run": "npm run dev",
      "build": "npm install",
      "env": {
        "PORT": "4000",
        "FRONTEND_URL": "http://localhost:3000",
        "SESSION_SECRET": "replace-with-long-random-string",
        "APP_ENCRYPTION_KEY": "replace-with-64-hex-characters",
        "SVP_API_BASE_URL": "https://svp-international-api.pacc.sa/api/v1",
        "SVP_LOCALE": "en",
        "RAILWAY_PRIVATE_DOMAIN": "appmain.railway.internal"
      }
    },
    "frontend": {
      "path": "frontend",
      "run": "npm run dev",
      "build": "npm install",
      "env": {
        "NEXT_PUBLIC_API_BASE_URL": "http://localhost:4000"
      }
    }
  }
}
